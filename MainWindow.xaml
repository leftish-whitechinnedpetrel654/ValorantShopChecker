<Window x:Class="CheckShopApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Valorant Shop Checker"
        Width="560" Height="760" MinWidth="440" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="{StaticResource BgBrush}"
        FontFamily="{StaticResource AppFont}"
        TextOptions.TextFormattingMode="Ideal"
        RenderOptions.BitmapScalingMode="HighQuality">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="46" ResizeBorderThickness="6"
                            CornerRadius="0" GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="46"/>
            <!-- başlık çubuğu -->
            <RowDefinition Height="Auto"/>
            <!-- alt başlık: cüzdan + sayaç -->
            <RowDefinition Height="*"/>
            <!-- içerik -->
            <RowDefinition Height="Auto"/>
            <!-- alt bilgi -->
        </Grid.RowDefinitions>

        <!-- ================= BAŞLIK ÇUBUĞU ================= -->
        <Grid Grid.Row="0" Background="#0B131B">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                <Border Width="26" Height="26" Background="{StaticResource AccentBrush}" CornerRadius="6">
                    <TextBlock Text="V" Foreground="White" FontWeight="Bold" FontSize="16"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="VALORANT" Foreground="{StaticResource TextBrush}" FontWeight="Bold"
                           FontSize="15" VerticalAlignment="Center" Margin="10,0,0,0"/>
                <TextBlock Text="SHOP" Foreground="{StaticResource AccentBrush}" FontWeight="Bold"
                           FontSize="15" VerticalAlignment="Center" Margin="5,0,0,0"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center"
                        Margin="0,0,8,0" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <Button x:Name="MinButton" Style="{StaticResource TitleBarButton}" Click="Minimize_Click"
                        Content="&#x2013;" ToolTip="Küçült"/>
                <Button x:Name="CloseButton" Style="{StaticResource CloseButton}" Click="Close_Click"
                        Content="&#x2715;" ToolTip="Kapat"/>
            </StackPanel>
        </Grid>

        <!-- ================= ALT BAŞLIK: cüzdan + bölge + sayaç ================= -->
        <Grid Grid.Row="1" Margin="18,16,18,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- üst satır: başlık + cüzdan çipleri -->
            <DockPanel Grid.Row="0">
                <TextBlock Text="GÜNLÜK MAĞAZA" Foreground="{StaticResource TextBrush}"
                           FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                    <Border Style="{StaticResource Chip}" Margin="6,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="VP" Foreground="{StaticResource AccentBrush}" FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock x:Name="VpText" Text="—" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" FontSize="13" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Chip}" Margin="6,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="RAD" Foreground="#6EE7D8" FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock x:Name="RadText" Text="—" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" FontSize="13" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </DockPanel>

            <!-- alt satır: sayaç + bölge + yenile -->
            <DockPanel Grid.Row="1" Margin="0,12,0,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Yenilenmeye kalan:" Foreground="{StaticResource SubTextBrush}" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock x:Name="CountdownText" Text="--:--:--" Foreground="{StaticResource TextBrush}"
                               FontSize="13" FontWeight="SemiBold" Margin="6,0,0,0" VerticalAlignment="Center"/>
                    <Border Style="{StaticResource Chip}" Margin="12,0,0,0" Padding="8,3">
                        <TextBlock x:Name="RegionText" Text="—" Foreground="{StaticResource SubTextBrush}" FontSize="11" FontWeight="Bold"/>
                    </Border>
                </StackPanel>
                <Button x:Name="RefreshButton" Style="{StaticResource AccentButton}" HorizontalAlignment="Right"
                        DockPanel.Dock="Right" Click="Refresh_Click" Content="⟳  Yenile"/>
            </DockPanel>
        </Grid>

        <!-- ================= İÇERİK (durumlar) ================= -->
        <Grid Grid.Row="2" Margin="10,4,10,4">

            <!-- MAĞAZA -->
            <ScrollViewer x:Name="ShopPanel" VerticalScrollBarVisibility="Auto" Padding="0,4">
                <ItemsControl x:Name="ShopItems">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="238" Margin="8" Background="{StaticResource CardBrush}" CornerRadius="10">
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" BlurRadius="14" ShadowDepth="0" Opacity="0.35"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="128"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" CornerRadius="10,10,0,0" Background="#0C1620">
                                        <Image Source="{Binding ImageUrl}" Stretch="Uniform" Margin="16,14"/>
                                    </Border>
                                    <Border Grid.Row="1" Height="3" VerticalAlignment="Top" Background="{StaticResource AccentBrush}"/>
                                    <StackPanel Grid.Row="1" Margin="14,12,14,14">
                                        <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextBrush}"
                                                   FontWeight="SemiBold" FontSize="14" TextTrimming="CharacterEllipsis"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                            <Border Width="16" Height="16" Background="{StaticResource AccentBrush}" CornerRadius="8">
                                                <TextBlock Text="V" Foreground="White" FontSize="10" FontWeight="Bold"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="{Binding PriceText}" Foreground="{StaticResource TextBrush}"
                                                       FontWeight="Bold" FontSize="14" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- YÜKLENİYOR -->
            <StackPanel x:Name="LoadingPanel" Visibility="Collapsed"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                <Ellipse Width="46" Height="46" Stroke="{StaticResource AccentBrush}" StrokeThickness="4"
                         StrokeDashArray="5 3" RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <RotateTransform x:Name="Spin"/>
                    </Ellipse.RenderTransform>
                    <Ellipse.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="Spin" Storyboard.TargetProperty="Angle"
                                                     From="0" To="360" Duration="0:0:1.1" RepeatBehavior="Forever"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Ellipse.Triggers>
                </Ellipse>
                <TextBlock Text="Mağaza yükleniyor…" Foreground="{StaticResource SubTextBrush}"
                           FontSize="13" Margin="0,16,0,0" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- HATA -->
            <StackPanel x:Name="ErrorPanel" Visibility="Collapsed" MaxWidth="380"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="⚠" Foreground="{StaticResource AccentBrush}" FontSize="40" HorizontalAlignment="Center"/>
                <TextBlock x:Name="ErrorText" Foreground="{StaticResource TextBrush}" FontSize="13"
                           TextWrapping="Wrap" TextAlignment="Center" Margin="0,14,0,0"/>
                <Button Style="{StaticResource AccentButton}" HorizontalAlignment="Center" Margin="0,20,0,0"
                        Click="Refresh_Click" Content="⟳  Tekrar dene"/>
            </StackPanel>
        </Grid>

        <!-- ================= ALT BİLGİ ================= -->
        <Border Grid.Row="3" Background="#0B131B" Padding="16,8">
            <TextBlock Foreground="{StaticResource SubTextBrush}" FontSize="11" TextAlignment="Center"
                       Text="Şifresiz • yerel Riot istemcisinden okur • resmî olmayan topluluk aracı"/>
        </Border>
    </Grid>
</Window>
